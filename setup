#!/bin/bash

set -euo pipefail

DOTFILES_REPO="https://github.com/fcosanabria/dotfiles.git"
DOTFILES_BRANCH="devpod"

# Bootstrap chezmoi and apply dotfiles
if ! command -v chezmoi >/dev/null 2>&1; then
  sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "$HOME/.local/bin" init --apply "$DOTFILES_REPO" --branch "$DOTFILES_BRANCH"
else
  chezmoi apply
fi
